{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const t=JSON.parse(d);const p=t.tool_input||{};const f=p.file_path||p.path||'';if(/config\\.prod\\.yml/.test(f))process.exit(2);})\""
          }
        ]
      }
    ]
  }
}
